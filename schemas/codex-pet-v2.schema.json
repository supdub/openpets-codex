{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/supdub/openpets-codex/raw/main/schemas/codex-pet-v2.schema.json",
  "title": "Codex desktop pet manifest v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "displayName",
    "description",
    "spriteVersionNumber",
    "spritesheetPath"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "displayName": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "spriteVersionNumber": {
      "const": 2
    },
    "spritesheetPath": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._-]+\\.(?:png|webp)$"
    }
  }
}
